<Application x:Class="ArtifactView.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>

        <!--
            Flat GroupBox: replaces the default raised/beveled border with a
            hairline outline and a compact dimmed header row.
        -->
        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- 1-px outline around the whole control -->
                            <Border Grid.RowSpan="2"
                                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                    BorderThickness="1"/>
                            <!-- Header row -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                    BorderThickness="0,0,0,1"
                                    Padding="8,3">
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  Focusable="False">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize"   Value="11"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Opacity"    Value="0.6"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </Border>
                            <!-- Content -->
                            <ContentPresenter Grid.Row="1"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            Flat DataGrid column header with geometric sort arrows.
            Preserves the resize grippers (PART_LeftHeaderGripper /
            PART_RightHeaderGripper) so column resizing still works.
        -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontSize"                   Value="11"/>
            <Setter Property="FontWeight"                 Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Grid>
                            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                    BorderThickness="0,0,1,1"
                                    Padding="4,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter VerticalAlignment="Center"
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    <!-- Ascending ▲ / Descending ▼ triangle -->
                                    <Path Grid.Column="1" Margin="4,0,2,0" VerticalAlignment="Center"
                                          Fill="{TemplateBinding Foreground}" Opacity="0.5">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Data" Value=""/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SortDirection,
                                                                     RelativeSource={RelativeSource TemplatedParent}}"
                                                                 Value="Ascending">
                                                        <Setter Property="Data" Value="M 0 4 L 3.5 0 L 7 4 Z"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SortDirection,
                                                                     RelativeSource={RelativeSource TemplatedParent}}"
                                                                 Value="Descending">
                                                        <Setter Property="Data" Value="M 0 0 L 3.5 4 L 7 0 Z"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Grid>
                            </Border>
                            <!-- Left gripper (must keep the PART_ name) -->
                            <Thumb x:Name="PART_LeftHeaderGripper"
                                   HorizontalAlignment="Left" Cursor="SizeWE" Width="4">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                            <!-- Right gripper -->
                            <Thumb x:Name="PART_RightHeaderGripper"
                                   HorizontalAlignment="Right" Cursor="SizeWE" Width="4">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Subtle alternating-row shading on every DataGrid in the app -->
        <Style TargetType="DataGrid">
            <Setter Property="AlternatingRowBackground"
                    Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
        </Style>

        <!--
            Global flat Button style (applies to all non-toolbar buttons:
            viewer Fit/1:1, path bar ↑, etc.).
            Toolbar buttons get their own style via ToolBar.ButtonStyleKey.
        -->
        <Style TargetType="Button">
            <Setter Property="Padding"          Value="8,3"/>
            <Setter Property="Background"
                    Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat TabControl: replaces the default 3D-bordered panel with a
             hairline outline that matches the GroupBox / DataGrid flat theme. -->
        <Style TargetType="TabControl">
            <Setter Property="BorderBrush"
                    Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"
                    Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Compact tab headers to leave more space for content -->
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding"  Value="10,3"/>
        </Style>

        <!--
            Flat GridViewColumnHeader for the Metadata-tab ListView.
            Matches the DataGridColumnHeader style above.
            PART_HeaderGripper must be preserved so column resizing works.
        -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="FontSize"                   Value="11"/>
            <Setter Property="FontWeight"                 Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Grid>
                            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                    BorderThickness="0,0,1,1"
                                    Padding="4,3">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                            <Thumb x:Name="PART_HeaderGripper"
                                   HorizontalAlignment="Right" Cursor="SizeWE" Width="4">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat status bar: hairline top border, no 3D sunken chrome -->
        <Style TargetType="StatusBar">
            <Setter Property="Background"
                    Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding"         Value="4,1"/>
        </Style>

        <Style TargetType="StatusBarItem">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding"  Value="0"/>
        </Style>

        <!--
            Flat ToolBar: removes the grip and overflow button;
            adds a hairline bottom border to tie into the layout.
        -->
        <Style TargetType="ToolBar">
            <Setter Property="Background"
                    Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolBar">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,0,0,1"
                                Padding="4,2">
                            <ToolBarPanel x:Name="PART_ToolBarPanel"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat toolbar button: transparent background, subtle hover/press highlight -->
        <Style x:Key="{x:Static ToolBar.ButtonStyleKey}" TargetType="Button">
            <Setter Property="Padding"          Value="8,3"/>
            <Setter Property="Margin"           Value="1,0"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderBrush"      Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thin vertical separator between toolbar button groups -->
        <Style x:Key="{x:Static ToolBar.SeparatorStyleKey}" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Width="1" Margin="4,3"
                                Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
