<Window x:Class="ArtifactView.App.Views.CompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compare"
        Width="1200" Height="700"
        MinWidth="600" MinHeight="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Black">
                <Image x:Name="LeftImage" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </Border>

            <Border Grid.Row="1" Padding="8,4"
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
                <StackPanel>
                    <TextBlock x:Name="LeftName" FontWeight="SemiBold" FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="LeftMeta" FontSize="11" Opacity="0.7"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                      Background="Transparent" ResizeBehavior="PreviousAndNext" />

        <!-- Right panel -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Black">
                <Image x:Name="RightImage" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </Border>

            <Border Grid.Row="1" Padding="8,4"
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
                <StackPanel>
                    <TextBlock x:Name="RightName" FontWeight="SemiBold" FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="RightMeta" FontSize="11" Opacity="0.7"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
